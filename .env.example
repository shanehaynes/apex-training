# Supabase — get these from your project's Settings > API page
# https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Service-role key — SERVER-SIDE ONLY. Never prefix with VITE_ (Vite would
# bundle it into client JS). Used by /api/* serverless functions to bypass
# RLS for writes. Also needs to be set in Vercel project env vars.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Anthropic — get from https://console.anthropic.com/settings/keys
# Used server-side only, by /api/chat and /api/coach-summary. Also needs
# to be set in Vercel project env vars. The legacy VITE_ANTHROPIC_API_KEY
# name still works as a fallback (no client code references it, so Vite
# never bundles it), but prefer this un-prefixed name for new setups.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Multi-user (phase 9): the auth user whose recurring workouts seed new
# accounts via /api/template-copy. Server-side only; set in Vercel too.
# Falls back to the profiles row with is_template_source = true.
SEED_SOURCE_USER_ID=00000000-0000-0000-0000-000000000000
